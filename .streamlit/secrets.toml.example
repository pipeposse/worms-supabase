# ════════════════════════════════════════════════════════════════════
#  EJEMPLO de secretos. NO pongas credenciales reales acá (este archivo
#  se sube a git). Las reales van en .streamlit/secrets.toml (ignorado por
#  git) o en Streamlit Cloud → Settings → Secrets.
# ════════════════════════════════════════════════════════════════════

# ── App (escritura) — rol postgres, igual que hoy ──────────────────────
DATABASE_URL = "postgresql://postgres.PROYECTO:TU_PASSWORD@aws-1-us-east-2.pooler.supabase.com:6543/postgres"

# ── Consultas IA (solo lectura) — rol ai_readonly, NO postgres ─────────
# Mismo host/puerto, pero usuario y password del rol read-only.
DATABASE_URL_RO = "postgresql://ai_readonly.PROYECTO:PASSWORD_READONLY@aws-1-us-east-2.pooler.supabase.com:6543/postgres"

# ── Gemini (gratis): https://aistudio.google.com/apikey ────────────────
GEMINI_API_KEY = "tu_api_key_de_gemini"
GEMINI_MODEL   = "gemini-2.0-flash"
