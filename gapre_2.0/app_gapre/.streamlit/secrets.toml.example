# Copiá este archivo a  .streamlit/secrets.toml  y completá la contraseña.
# NO subas secrets.toml a git (ya está en .gitignore).
#
# Para Streamlit Community Cloud usá el CONNECTION POOLER de Supabase (IPv4),
# NO el host directo db.xxx.supabase.co (es IPv6 y Streamlit Cloud no lo soporta).
# Lo sacás en: Supabase > Project Settings > Database > Connection string > Transaction pooler.

[db]
# Pooler (recomendado para Streamlit Cloud) — puerto 6543:
dsn = "postgresql://postgres.svgmmfcmifsafmdnvhzf:TU_PASSWORD@aws-0-us-east-2.pooler.supabase.com:6543/postgres?sslmode=require"

# Alternativa para correr LOCAL (conexión directa, puerto 5432):
# dsn = "postgresql://postgres:TU_PASSWORD@db.svgmmfcmifsafmdnvhzf.supabase.co:5432/postgres?sslmode=require"
